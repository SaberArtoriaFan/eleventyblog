---
templateClass: tmpl-chapter
---
{% extends "layouts/base.njk" %}

{% block extraArticleHeader %}
<aside>
  <a href="/books/{{ book }}/" class="book-link">📚 {{ book }}</a>
</aside>
{% endblock %}

{% block footerAuthor %}{{ metadata.author.name }}{% endblock %}

{% block article %}
<div class="reader-settings">
  <button class="settings-toggle" aria-label="阅读设置">⚙️</button>
  <div class="settings-panel">
    <div class="setting-item">
      <label>主题</label>
      <div class="theme-buttons">
        <button class="theme-btn" data-theme="light" aria-label="日间模式">☀️</button>
        <button class="theme-btn" data-theme="dark" aria-label="夜间模式">🌙</button>
        <button class="theme-btn" data-theme="sepia" aria-label="护眼模式">🍂</button>
      </div>
    </div>
    <div class="setting-item">
      <label>字号</label>
      <input type="range" id="font-size" min="14" max="24" value="18">
      <span id="font-size-value">18px</span>
    </div>
    <div class="setting-item">
      <label>宽度</label>
      <input type="range" id="content-width" min="600" max="1000" value="800">
      <span id="content-width-value">800px</span>
    </div>
    <div class="setting-item">
      <label>行高</label>
      <input type="range" id="line-height" min="16" max="28" value="20">
      <span id="line-height-value">2.0</span>
    </div>
    <div class="setting-item">
      <label>段间距</label>
      <input type="range" id="paragraph-gap" min="5" max="40" value="15">
      <span id="paragraph-gap-value">1.5em</span>
    </div>
  </div>
</div>

<button class="scroll-bottom-btn" id="scroll-bottom" aria-label="跳到底部">↓</button>

<div class="chapter-wrapper" id="chapter-wrapper">
<h1 class="chapter-title">{{ title }}</h1>

<div class="chapter-content" id="chapter-content">
{{ content | safe }}
</div>

<hr>

<nav class="chapter-nav">
{% set chapters = collections.bookChapters[book] %}
{% set chapterIndex = 0 %}
{% for ch in chapters %}
  {% if ch.url == page.url %}
    {% set chapterIndex = loop.index0 %}
  {% endif %}
{% endfor %}
{% if chapterIndex > 0 %}<a href="{{ chapters[chapterIndex - 1].url }}" class="prev">← 上一章</a>{% endif %}
<span class="chapter-info">第 {{ chapterIndex + 1 }} 章</span>
{% if chapterIndex < chapters.length - 1 %}<a href="{{ chapters[chapterIndex + 1].url }}" class="next">下一章 →</a>{% endif %}
</nav>

<nav class="book-nav">
<a href="/books/{{ book }}/">返回目录</a>
</nav>
</div>

<script csp-hash>
(function() {
  var wrapper = document.getElementById('chapter-wrapper');
  var content = document.getElementById('chapter-content');
  var fontSizeInput = document.getElementById('font-size');
  var widthInput = document.getElementById('content-width');
  var lineHeightInput = document.getElementById('line-height');
  var paragraphGapInput = document.getElementById('paragraph-gap');
  var fontSizeVal = document.getElementById('font-size-value');
  var widthVal = document.getElementById('content-width-value');
  var lineHeightVal = document.getElementById('line-height-value');
  var paragraphGapVal = document.getElementById('paragraph-gap-value');
  var toggle = document.querySelector('.settings-toggle');
  var panel = document.querySelector('.settings-panel');

  function applySettings() {
    var fs = fontSizeInput.value + 'px';
    var w = widthInput.value + 'px';
    var lh = (lineHeightInput.value / 10).toFixed(1);
    var pg = (paragraphGapInput.value / 10).toFixed(1) + 'em';

    wrapper.style.maxWidth = w;
    content.style.fontSize = fs;
    content.style.lineHeight = lh;
    content.style.setProperty('--paragraph-gap', pg);

    fontSizeVal.textContent = fs;
    widthVal.textContent = w;
    lineHeightVal.textContent = lh;
    paragraphGapVal.textContent = pg;
  }

  function saveSettings() {
    localStorage.setItem('reader-settings', JSON.stringify({
      fontSize: fontSizeInput.value,
      contentWidth: widthInput.value,
      lineHeight: lineHeightInput.value,
      paragraphGap: paragraphGapInput.value,
      theme: currentTheme
    }));
  }

  var currentTheme = 'dark';

  function applyTheme(theme) {
    currentTheme = theme;
    document.body.setAttribute('data-theme', theme);
    // 更新按钮状态
    document.querySelectorAll('.theme-btn').forEach(function(btn) {
      btn.classList.toggle('active', btn.dataset.theme === theme);
    });
  }

  function loadSettings() {
    var saved = localStorage.getItem('reader-settings');
    if (saved) {
      var s = JSON.parse(saved);
      fontSizeInput.value = s.fontSize || 18;
      widthInput.value = s.contentWidth || 800;
      lineHeightInput.value = s.lineHeight || 20;
      paragraphGapInput.value = s.paragraphGap || 15;
      if (s.theme) {
        applyTheme(s.theme);
      } else {
        applyTheme('dark');
      }
    } else {
      applyTheme('dark');
    }
    applySettings();
  }

  fontSizeInput.addEventListener('input', function() { applySettings(); saveSettings(); });
  widthInput.addEventListener('input', function() { applySettings(); saveSettings(); });
  lineHeightInput.addEventListener('input', function() { applySettings(); saveSettings(); });
  paragraphGapInput.addEventListener('input', function() { applySettings(); saveSettings(); });

  // 主题切换
  document.querySelectorAll('.theme-btn').forEach(function(btn) {
    btn.addEventListener('click', function() {
      applyTheme(this.dataset.theme);
      saveSettings();
    });
  });

  toggle.addEventListener('click', function(e) {
    e.stopPropagation();
    panel.classList.toggle('open');
  });

  document.addEventListener('click', function(e) {
    if (!e.target.closest('.reader-settings')) {
      panel.classList.remove('open');
    }
  });

  loadSettings();

  // 滚动到底部按钮
  var scrollBottomBtn = document.getElementById('scroll-bottom');
  scrollBottomBtn.addEventListener('click', function() {
    window.scrollTo({
      top: document.body.scrollHeight,
      behavior: 'smooth'
    });
  });
})();
</script>
{% endblock %}
