<header class="book-header">
  <h1>{{ bookName }}</h1>
  {% if author %}<p class="book-author">作者：{{ author }}</p>{% endif %}
</header>

{% if cover %}
<div class="book-cover">
  <img src="{{ cover }}" alt="{{ bookName }}" loading="lazy">
</div>
{% endif %}

{% if description %}
<div class="book-description">
  {{ description }}
</div>
{% endif %}

<section class="chapters-list">
  <h2>📖 章节目录</h2>
  {% set bookChapters = collections.bookChapters[bookName] %}
  {% if bookChapters %}
  <ol>
  {% for chapter in bookChapters %}
    <li>
      <a href="{{ chapter.url }}">{{ chapter.data.title }}</a>
    </li>
  {% endfor %}
  </ol>
  {% else %}
  <p>暂无章节</p>
  {% endif %}
</section>

<a href="/" class="back-link">← 返回书架</a>